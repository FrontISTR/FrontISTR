!VERSION
    5
!SOLUTION, TYPE = NLSTATIC
# !DLOAD with VALUE=ABSOLUTE: the amplitude value replaces the load
# magnitude (params(0)). Here the P2 pressure card value is 7.0 but the
# ABSOLUTE amplitude reaches 50.0, so the applied pressure is 50.0,
# matching a plain P2 pressure of 50.0 driven by a RELATIVE amplitude 1.0.
!BOUNDARY, GRPID = 1
 1, 1,3, 0.0
 2, 1,3, 0.0
 3, 1,3, 0.0
 4, 1,3, 0.0
 5, 1,2, 0.0
 6, 1,2, 0.0
 7, 1,2, 0.0
 8, 1,2, 0.0
!DLOAD, GRPID = 1, AMP=AMP1
 1, P2, 7.0
!STEP, SUBSTEPS = 2, CONVERG=1.E-8
  BOUNDARY,    1
  LOAD, 1
!MATERIAL, NAME=M1
!ELASTIC
  10.0E+04,   0.3
!WRITE, RESULT, FREQUENCY=1
!OUTPUT_RES
 DISP, ON
 NSTRESS, OFF
 NMISES, OFF
!SOLVER, METHOD = CG, PRECOND = 3, ITERLOG = NO, TIMELOG = NO
  10000,       1
 1.0E-8,     1.0,     0.0
!END
