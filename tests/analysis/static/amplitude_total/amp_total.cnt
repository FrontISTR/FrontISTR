!VERSION
    5
!SOLUTION, TYPE = NLSTATIC
# TIME=TOTAL TIME: the amplitude is evaluated against the accumulated total
# time, not the step-local time. The load (GRPID=2) is activated only in the
# 2nd step so it is governed solely by the amplitude (no cross-step reset).
# At the end of step 2 the total time is 2.0, where AMP1 = 1.0, so the load is
# 100.0. Under the default STEP TIME the same curve would give AMP1(t_local=1.0)
# = 0.5 (load 50.0); TOTAL TIME therefore yields ~2x the response.
!BOUNDARY, GRPID = 1
 1, 1,3, 0.0
 2, 1,3, 0.0
 3, 1,3, 0.0
 4, 1,3, 0.0
 5, 1,3, 0.0
 6, 1,3, 0.0
 7, 1,3, 0.0
 8, 1,2, 0.0
!CLOAD, GRPID = 2, AMP=AMP1
 8, 3, 100
!STEP, SUBSTEPS = 1, CONVERG=1.E-8
  BOUNDARY,    1
!STEP, SUBSTEPS = 1, CONVERG=1.E-8
  BOUNDARY,    1
  LOAD, 2
!MATERIAL, NAME=M1
!ELASTIC
  10.0E+04,   0.3
!WRITE, RESULT, FREQUENCY=1
!OUTPUT_RES
 DISP, ON
 NSTRESS, OFF
 NMISES, OFF
!SOLVER, METHOD = CG, PRECOND = 3, ITERLOG = NO, TIMELOG = NO
  10000,       1
 1.0E-8,     1.0,     0.0
!END
