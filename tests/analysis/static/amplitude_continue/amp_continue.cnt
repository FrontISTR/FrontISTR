!VERSION
    5
!SOLUTION, TYPE = NLSTATIC
# Amplitude on a load that stays active across multiple steps.
#
# The load (GRPID=2, CLOAD) is active in BOTH steps. An explicit AMP= is given,
# so the amplitude must be honored in every active step. In fstr_ass_load the
# "continuing load is held at nominal" override is gated on the absence of an
# amplitude:
#   if (jj_n_amp <= 0 .and. fstr_isLoadActive(...,cstep-1)) aval = fval
# so it does NOT fire here and the amplitude governs step 2 as well.
#
# AMP1 (default TIME=STEP TIME, VALUE=RELATIVE) reaches 2.0 at step-local t=1.0.
# Card value is 100, so each step applies 100*2.0 = 200 at its end:
#   step 1 end (t_local=1): load 200
#   step 2 end (t_local=1): load 200   <- amplitude honored, NOT held at 100
# If the override were applied to amplitude loads, step 2 would collapse to the
# nominal 100 (half the displacement); this test locks the honored behavior.
!BOUNDARY, GRPID = 1
 1, 1,3, 0.0
 2, 1,3, 0.0
 3, 1,3, 0.0
 4, 1,3, 0.0
 5, 1,3, 0.0
 6, 1,3, 0.0
 7, 1,3, 0.0
 8, 1,2, 0.0
!CLOAD, GRPID = 2, AMP=AMP1
 8, 3, 100
!STEP, SUBSTEPS = 1, CONVERG=1.E-8
  BOUNDARY,    1
  LOAD, 2
!STEP, SUBSTEPS = 1, CONVERG=1.E-8
  BOUNDARY,    1
  LOAD, 2
!MATERIAL, NAME=M1
!ELASTIC
  10.0E+04,   0.3
!WRITE, RESULT, FREQUENCY=1
!OUTPUT_RES
 DISP, ON
 NSTRESS, OFF
 NMISES, OFF
!SOLVER, METHOD = CG, PRECOND = 3, ITERLOG = NO, TIMELOG = NO
  10000,       1
 1.0E-8,     1.0,     0.0
!END
