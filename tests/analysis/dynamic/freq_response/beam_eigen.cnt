# Eigen analysis that produces the mode-superposition fixtures for beam.cnt
# (beam_eig.res.0.* eigenvectors + beam_eig.log eigenvalues). Not run by test.sh;
# create_reference.sh runs it automatically when regenerating the references.
!VERSION
 3
!WRITE,RESULT
!SOLUTION, TYPE=EIGEN
!EIGEN
 3, 1.0E-8, 60
!BOUNDARY
 _PickedSet4, 1, 3, 0.0
!SOLVER,METHOD=CG,PRECOND=1,ITERLOG=NO,TIMELOG=YES
 10000, 1
 1.0e-8, 1.0, 0.0
!END
