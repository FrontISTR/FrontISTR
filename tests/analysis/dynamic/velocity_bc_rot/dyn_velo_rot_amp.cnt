########################################################
## Dynamic implicit analysis: rotational velocity BC
##   with AMPLITUDE (time-dependent angular velocity).
##   wz(t) = 0.1 * amp(t), amp: 0 -> 1 linear over [0,1].
##   Imposed on all nodes via
##   !VELOCITY, AMP=AMP_SPIN, ROT_CENTER=CENTER.
##   Check: |v(t)| = wz(t) * (distance from z-axis).
########################################################
!VERSION
 3
!SOLUTION, TYPE=DYNAMIC
!DYNAMIC
 1 , 1
 0.0, 1.0, 10, 0.1
 0.5, 0.25
 1, 1, 0.0, 0.0
 100, 1, 100
 1, 1, 1, 1, 1, 1
###################################
#####   BOUNDARY CONDITIONS   #####
###################################
!VELOCITY, TYPE=TRANSIT, AMP=AMP_SPIN, ROT_CENTER=CENTER
 ALLN, 1, 1, 0.0
 ALLN, 2, 2, 0.0
 ALLN, 3, 3, 0.1
###################################
#####         MATERIAL        #####
###################################
!MATERIAL, NAME=MAT1
!ELASTIC
 1.00000000E+02, 3.00000000E-01
!DENSITY
 1.00000000E-03
###################################
#####       SOLVER CONTROL    #####
###################################
!SOLVER,METHOD=CG,PRECOND=1,ITERLOG=NO,TIMELOG=NO
 500000, 2
 1.00e-08, 1.00, 0.0
!STEP, SUBSTEPS=20
0.1, 1.0, 1.0E-3, 0.1
BOUNDARY, 1
!WRITE,RESULT,FREQUENCY=5
!OUTPUT_RES
 DISP,ON
 VEL,ON
 ACC,ON
!END
