###############################################
## Dynamic implicit analysis: Auto-increment
## CLOAD with AMPLITUDE, INC_TYPE=AUTO, NLGEOM
## Moderate load so Newton converges in 2-4 iter
## -> time step should increase via autoinc
###############################################
!VERSION
 3
!SOLUTION, TYPE=DYNAMIC
!DYNAMIC, TYPE=NONLINEAR
 1 , 1
 0.0, 1.0, 100, 0.1
 0.5, 0.25
 1, 1, 0.0, 0.0
 100, 1, 100
 1, 1, 1, 1, 1, 1
###################################
#####   BOUNDARY CONDITIONS   #####
###################################
!BOUNDARY, GRPID=1
 FIX, 1, 3, 0.0
!CLOAD, GRPID=1, AMP=AMP1
 LOAD, 2, -1.0
###################################
#####         MATERIAL        #####
###################################
!MATERIAL, NAME=MAT1
!ELASTIC
 1.00000000E+02, 3.00000000E-01
!DENSITY
 1.00000000E-03
###################################
#####       SOLVER CONTROL    #####
###################################
!SOLVER,METHOD=CG,PRECOND=1,ITERLOG=NO,TIMELOG=NO
 500000, 2
 1.00e-08, 1.00, 0.0
!AUTOINC_PARAM, NAME=AP1
 0.5, 10, 50, 10, 1
 2.0,  5, 20,  5, 2
 0.5,  5
!STEP, SUBSTEPS=13, MAXITER=20, CONVERG=1.0E-6, INC_TYPE=AUTO, AUTOINCPARAM=AP1
 0.05, 1.0, 1.0E-4, 0.5
 BOUNDARY, 1
 LOAD, 1
!WRITE,RESULT,FREQUENCY=9999
!OUTPUT_RES
 DISP,ON
 VEL,ON
 ACC,ON
!END
