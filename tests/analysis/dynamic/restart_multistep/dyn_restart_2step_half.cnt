###############################################
## Dynamic implicit analysis: 2-step restart test
## Half run: Step 1 only (writes restart at step end)
###############################################
!VERSION
 3
!SOLUTION, TYPE=DYNAMIC
!DYNAMIC
 1 , 1
 0.0, 1.0, 10, 0.1
 0.5, 0.25
 1, 1, 0.0, 0.0
 100, 1, 100
 1, 1, 1, 1, 1, 1
!RESTART, FREQUENCY=1
!BOUNDARY, GRPID=1
 FIX, 1, 3, 0.0
!CLOAD, GRPID=1
 LOAD, 2, -1.0
!MATERIAL, NAME=MAT1
!ELASTIC
 1.00000000E+02, 3.00000000E-01
!DENSITY
 1.00000000E-03
!SOLVER,METHOD=CG,PRECOND=1,ITERLOG=NO,TIMELOG=NO
 500000, 2
 1.00e-08, 1.00, 0.0
!STEP, SUBSTEPS=5
 0.1, 0.5
 BOUNDARY, 1
 LOAD, 1
!WRITE,RESULT,FREQUENCY=5
!OUTPUT_RES
 DISP,ON
 VEL,ON
 ACC,ON
!END
