###################################################################
#  Dynamic IMPLICIT contact FRICTION regression test (work item #777)
#
#  Verifies that the tangential (friction) contact force is committed
#  across time increments in the dynamic implicit SLagrange path
#  (fstr_update_contact_TangentForce in fstr_dynamic_nlimplicit.f90).
#
#  Model: 2 hexa boxes. Bottom box base (z=0, SET_3) fixed.  Top box is
#  pressed down by a distributed surface pressure (DLOAD P3 on SET_4 top
#  face, normal=-z) -> steady normal contact (lambda>0), and dragged in +x
#  by a small CLOAD kept below mu*N so the interface STICKS:
#      N   = P*A   = 2.0*(0.9*0.9) = 1.62
#      muN = 0.3*N = 0.486 ;  tangential = 9*0.022 = 0.198  (ratio 0.41 < 1)
#  With the fix, friction accumulates over increments and resists the drag
#  (CONTACT_FRICTION ~ applied tangential).  Without it, the friction history
#  is lost each increment, friction under-develops and the top box drifts.
###################################################################
!VERSION
 3
!SOLUTION, TYPE=DYNAMIC, NONLINEAR
!CONTACT_ALGO, TYPE=SLAGRANGE
!WRITE,RESULT,FREQUENCY=10
!OUTPUT_RES
DISP,ON
REACTION,ON
CONTACT_NFORCE,ON
CONTACT_FRICTION,ON
CONTACT_STATE,ON
!SOLVER,METHOD=GMRES,PRECOND=1,NSET=0,ITERLOG=NO,TIMELOG=NO
 5000, 1
 1.0e-08, 1.00, 0.0
!DYNAMIC
 1, 1
 0.0, 1.0, 5, 0.2
 0.5, 0.25
 1, 1, 20.0, 0.1
 100, 1, 100
 1, 1, 1, 1, 1, 1
!BOUNDARY, GRPID=1
 SET_3, 1, 3, 0.0
!BOUNDARY, GRPID=2
 SET_4, 2, 2, 0.0
!DLOAD, GRPID=3, AMP=RAMP
 SET_4, P3, 2.0
!CLOAD, GRPID=4, AMP=RAMP
 SET_4, 1, 0.022
!CONTACT, INTERACTION=FSLID, GRPID=1
 CP1, 0.3, 5.0E+2
!MATERIAL, NAME=MATERIAL_1
!ELASTIC
 1.00000000E+03, 3.00000000E-01
!DENSITY
 1.00000000E+00
!STEP, CONVERG=1.0e-6
0.2, 1.0, 0.001, 1.0
 BOUNDARY,1
 BOUNDARY,2
 LOAD,3
 LOAD,4
 CONTACT,1
!END
