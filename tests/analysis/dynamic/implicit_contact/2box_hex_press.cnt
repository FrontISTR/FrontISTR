###################################################################
#  Dynamic IMPLICIT contact output test - INFINITESIMAL (no NONLINEAR)
#
#  Guards that the SLagrange contact output forces CONT_NFORCE/CONT_FRIC
#  are produced even when the analysis is infinitesimal (NONLINEAR not
#  specified, i.e. fstrPARAM%nlgeom = .false.).
#
#  In the dynamic implicit path the Lagrange multipliers must be accumulated
#  before the nlgeom early-exit; otherwise hecLagMAT%lagrange stays zero and
#  CONT_NFORCE/CONT_FRIC (computed from the multipliers) are always zero even
#  though the contact constraint is enforced and reactions are correct.
#
#  Model: two hexa boxes, base (SET_3) fixed, top face (SET_4) held laterally
#  (dof1,2) and pressed straight down by a surface pressure (DLOAD P3).
#  Frictionless (fcoeff=0) to keep this independent of the friction fix (#777).
#    expected: CONT_NFORCE_z total = P*A = 2.0*(0.9*0.9) = 1.62  (non-zero)
###################################################################
!VERSION
 3
!SOLUTION, TYPE=DYNAMIC
!CONTACT_ALGO, TYPE=SLAGRANGE
!WRITE,RESULT,FREQUENCY=5
!OUTPUT_RES
DISP,ON
REACTION,ON
CONTACT_NFORCE,ON
CONTACT_STATE,ON
!SOLVER,METHOD=GMRES,PRECOND=1,NSET=0,ITERLOG=NO,TIMELOG=NO
 5000, 1
 1.0e-08, 1.00, 0.0
!DYNAMIC
 1, 1
 0.0, 1.0, 5, 0.2
 0.5, 0.25
 1, 1, 20.0, 0.1
 100, 1, 100
 1, 1, 1, 1, 1, 1
!BOUNDARY, GRPID=1
 SET_3, 1, 3, 0.0
!BOUNDARY, GRPID=2
 SET_4, 1, 2, 0.0
!DLOAD, GRPID=3, AMP=RAMP
 SET_4, P3, 2.0
!CONTACT, INTERACTION=FSLID, GRPID=1
 CP1, 0.0, 5.0E+2
!MATERIAL, NAME=MATERIAL_1
!ELASTIC
 1.00000000E+03, 3.00000000E-01
!DENSITY
 1.00000000E+00
!STEP, CONVERG=1.0e-6
0.2, 1.0, 0.001, 1.0
 BOUNDARY,1
 BOUNDARY,2
 LOAD,3
 CONTACT,1
!END
