###############################################
## Dynamic implicit analysis: CLOAD with AMPLITUDE
## Ramp load in Y-direction on free end
## NOTE: No !VERSION / no !STEP params for origin-commit compatibility
###############################################
!SOLUTION, TYPE=DYNAMIC
!DYNAMIC
 1 , 1
 0.0, 2.0, 10, 0.2
 0.5, 0.25
 1, 1, 0.0, 0.0
 100, 1, 100
 1, 1, 1, 1, 1, 1
###################################
#####   BOUNDARY CONDITIONS   #####
###################################
!BOUNDARY
 FIX, 1, 3, 0.0
!CLOAD, AMP=AMP1
 LOAD, 2, -1.0
###################################
#####         MATERIAL        #####
###################################
!MATERIAL, NAME=MAT1
!ELASTIC
 1.00000000E+02, 3.00000000E-01
!DENSITY
 1.00000000E-03
###################################
#####       SOLVER CONTROL    #####
###################################
!SOLVER,METHOD=CG,PRECOND=1,ITERLOG=NO,TIMELOG=NO
 500000, 2
 1.00e-08, 1.00, 0.0
!STEP
!WRITE,RESULT,FREQUENCY=5
!OUTPUT_RES
 DISP,ON
 VEL,ON
 ACC,ON
!END
