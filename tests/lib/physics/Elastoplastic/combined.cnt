!VERSION
    3
!SOLUTION, TYPE = NLSTATIC
# Uniaxial strain-controlled cyclic test for COMBINED (isotropic + linear kinematic)
# hardening. Guards the back-stress accumulation fix (sub-step independence) and the
# combined-hardening reversal (elastic span = 2*sigma_y_current, larger than 2*sigma_y0
# because the isotropic part has expanded the yield surface).
#   E=1.0e5, nu=0.3, sigma_y0=1000, H(isotropic)=5.0e4, C(kinematic)=5.0e4
#   strain path: 0 -> 0.05 (tension) -> -0.01 (reverse)
#   hand-calc: monotonic slope = H+C = 1.0e5 -> sigma_xx ~ +2931 at eps=0.05
#              at eps=0.05: sigma_y_iso=sigma_y0+H*eps_p=2000, back stress=C*eps_p=1000
#              reverse-yield span = 2*sigma_y_iso ~ 4000 ; sigma_xx ~ -1955 at eps=-0.01
!BOUNDARY, GRPID = 1
        1,        1,        3,   0.0
        4,        1,        1,   0.0
        4,        3,        3,   0.0
        5,        1,        2,   0.0
        8,        1,        1,   0.0
!BOUNDARY, GRPID = 2
        2,        1,        1,   0.05
        3,        1,        1,   0.05
        6,        1,        1,   0.05
        7,        1,        1,   0.05
!BOUNDARY, GRPID = 3
        2,        1,        1,  -0.06
        3,        1,        1,  -0.06
        6,        1,        1,  -0.06
        7,        1,        1,  -0.06
!STEP, SUBSTEPS = 10, CONVERG=1.E-8
  BOUNDARY,    1
  BOUNDARY,    2
!STEP, SUBSTEPS = 12, CONVERG=1.E-8
  BOUNDARY,    1
  BOUNDARY,    3
!MATERIAL, NAME=M1
!ELASTIC, INFINITESIMAL
  10.0E+04,   0.3
!PLASTIC, HARDEN=COMBINED
  1000., 5.0E+04, 5.0E+04
!WRITE, RESULT, FREQUENCY=2
!ELEMENT_OUTPUT, POSITION=INTEG
   STRAIN
   STRESS
   PLSTRAIN
!SOLVER, METHOD = CG, PRECOND = 3, ITERLOG = NO, TIMELOG = NO
  10000,       1
 1.0E-8,     1.0,     0.0
!END
