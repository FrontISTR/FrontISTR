!VERSION
    3
!SOLUTION, TYPE = NLSTATIC
# Uniaxial strain-controlled cyclic test for linear KINEMATIC (Prager) hardening.
# Verifies the Bauschinger effect (reverse-yield elastic span = 2*sigma_y0) and that
# the response is sub-step independent (regression guard for the back-stress
# accumulation fix in Elastoplastic.f90 BackwardEuler_VM).
#   E=1.0e5, nu=0.3, sigma_y0=1000, C(kinematic)=1.0e5
#   strain path: 0 -> 0.05 (tension) -> 0.01 (reverse)
#   hand-calc: sigma_xx ~ +2931 at eps=0.05 ; sigma_xx ~ 0 at eps=0.01 after reversal
#   (isotropic hardening would give sigma_xx ~ -1000 at eps=0.01: Bauschinger signature)
#   checked snapshots: .10 = tension peak (eps=0.05), .20 = reversal end (eps=0.01)
!BOUNDARY, GRPID = 1
        1,        1,        3,   0.0
        4,        1,        1,   0.0
        4,        3,        3,   0.0
        5,        1,        2,   0.0
        8,        1,        1,   0.0
!BOUNDARY, GRPID = 2
        2,        1,        1,   0.05
        3,        1,        1,   0.05
        6,        1,        1,   0.05
        7,        1,        1,   0.05
!BOUNDARY, GRPID = 3
        2,        1,        1,  -0.04
        3,        1,        1,  -0.04
        6,        1,        1,  -0.04
        7,        1,        1,  -0.04
!STEP, SUBSTEPS = 10, CONVERG=1.E-8
  BOUNDARY,    1
  BOUNDARY,    2
!STEP, SUBSTEPS = 10, CONVERG=1.E-8
  BOUNDARY,    1
  BOUNDARY,    3
!MATERIAL, NAME=M1
!ELASTIC, INFINITESIMAL
  10.0E+04,   0.3
!PLASTIC, HARDEN=KINEMATIC
  1000., 1.0E+05
!WRITE, RESULT, FREQUENCY=10
!ELEMENT_OUTPUT, POSITION=INTEG
   STRAIN
   STRESS
   PLSTRAIN
!SOLVER, METHOD = CG, PRECOND = 3, ITERLOG = NO, TIMELOG = NO
  10000,       1
 1.0E-8,     1.0,     0.0
!END
