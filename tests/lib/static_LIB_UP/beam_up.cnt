##
## Cantilever beam bending test for UP (u-p) formulation
##   Mesh: 5x1x1 hex (5 elements), L=5, b=h=1
##   Material: E=1000, nu=0.499999 (nearly incompressible)
##   Load: tip concentrated force F=-2.0 (y-dir) at nodes 1,3 (SET_4)
##   BC: fixed end x=0 (SET_1)
##   Solver: MUMPS direct, NLSTATIC 10 substeps
##
## Purpose:
##   Verify that UP elements avoid volumetric locking in bending
##   of nearly incompressible material (nu->0.5).
##
## Results (step 10, full load):
##   UP:  tip deflection uy = -1.368 (132% of Timoshenko theory)
##   FI:  tip deflection uy = -0.030 (  3% of Timoshenko theory) <- locking!
##   Timoshenko theory:       -1.036
##   Volume change: UP -0.065%, FI -0.002% (FI barely deforms)
##   Coarse mesh (5 elem) overestimates with UP; refine to converge.
##
!VERSION
 3
!SOLUTION, TYPE=NLSTATIC
!WRITE,LOG
!WRITE,RESULT
!SOLVER,METHOD=MUMPS,ITERLOG=NO,TIMELOG=NO
 10000, 1
 1.0e-08, 1.00, 0.0
!BOUNDARY, GRPID=1
 SET_1,1,1
 SET_1,2,2
 SET_1,3,3
!CLOAD, GRPID=1
 SET_4,2,-1.0
!MATERIAL, NAME=MATERIAL1
!ELASTIC
 1.0000E+03, 4.99999E-01
!SECTION, SECNUM=1, FORM361=UP
!STEP, SUBSTEPS=10, CONVERG=1.0E-06
 BOUNDARY,1
 LOAD,1
!END
